+<!DOCTYPE html>
+<html lang="zh-CN">
+  <head>
+    <meta charset="UTF-8" />
+    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
+    <title>照片灵感墙</title>
+    <link rel="stylesheet" href="/public/styles.css" />
+  </head>
+  <body>
+    <div class="page-shell">
+      <header class="hero-card">
+        <div>
+          <p class="eyebrow">照片分享 · 审核版初版</p>
+          <h1>先投稿，后审核，通过后再公开展示。</h1>
+          <p class="hero-copy">
+            访客提交照片后，系统会把图片和完整文字信息发送到管理员邮箱；
+            管理员点击邮件中的“审核通过 / 审核不通过”按钮后，网站才会更新展示结果。
+          </p>
+        </div>
+        <div class="hero-badge">先审核<br />再上墙</div>
+      </header>
+
+      <main>
+        <section class="composer-card">
+          <div class="upload-panel">
+            <label for="imageInput" class="upload-dropzone">
+              <input id="imageInput" type="file" accept="image/*" hidden />
+              <div class="upload-icon">📷</div>
+              <strong id="uploadTitle">点击上传图片</strong>
+              <span id="uploadHint">支持 PNG、JPG、WebP、GIF、BMP、SVG、HEIC、AVIF 等格式</span>
+              <img id="previewImage" alt="预览图片" hidden />
+            </label>
+            <div class="audit-tips">
+              <h3>审核说明</h3>
+              <ul>
+                <li>用户提交后默认进入“待审核”状态。</li>
+                <li>管理员邮箱会收到图片、文字信息和审核按钮。</li>
+                <li>只有审核通过的作品，才会出现在下方榜单。</li>
+              </ul>
+              <p id="mailConfigNote">正在读取邮箱审核配置…</p>
+            </div>
+          </div>
+
+          <form class="meta-form" id="photoForm">
+            <div class="field-grid">
+              <label>
+                <span>作品名称</span>
+                <input name="title" maxlength="80" placeholder="例如：黄昏中的城市剪影" required />
+              </label>
+              <label>
+                <span>作者</span>
+                <input name="author" maxlength="40" placeholder="例如：王小明" required />
+              </label>
+              <label>
+                <span>一句话描述</span>
+                <input name="description" maxlength="160" placeholder="一句话描述这个作品的亮点" required />
+              </label>
+              <label>
+                <span>应用场景</span>
+                <input name="scenario" maxlength="60" placeholder="例如：旅行海报 / 品牌宣传 / 社媒配图" required />
+              </label>
+              <label>
+                <span>联系方式</span>
+                <input name="contact" maxlength="80" placeholder="邮箱、微信、手机号等" required />
+              </label>
+            </div>
+            <div class="actions-row">
+              <button type="submit" class="primary-btn">提交审核</button>
+              <p class="form-status" id="formStatus">填写完成后即可提交审核。</p>
+            </div>
+          </form>
+        </section>
+
+        <section class="gallery-section">
+          <div class="section-head">
+            <div>
+              <p class="eyebrow">公开榜单</p>
+              <h2>这里只展示已审核通过的作品</h2>
+            </div>
+            <p class="refresh-note" id="refreshNote">正在加载作品列表…</p>
+          </div>
+          <div class="gallery-grid" id="galleryGrid"></div>
+        </section>
+      </main>
+    </div>
+
+    <template id="photoCardTemplate">
+      <article class="photo-card">
+        <div class="card-rank"></div>
+        <img class="card-image" alt="作品图片" />
+        <div class="card-body">
+          <div class="card-topline">
+            <h3 class="card-title"></h3>
+            <span class="likes-pill">❤️ <span class="likes-value"></span></span>
+          </div>
+          <p class="card-author"></p>
+          <p class="card-description"></p>
+          <dl class="card-meta">
+            <div><dt>应用场景</dt><dd class="scenario"></dd></div>
+            <div><dt>联系方式</dt><dd class="contact"></dd></div>
+            <div><dt>审核通过时间</dt><dd class="approved-at"></dd></div>
+          </dl>
+          <div class="card-actions">
+            <button class="like-btn" type="button">点赞</button>
+            <span class="vote-feedback">点赞后将触发小动画</span>
+          </div>
+        </div>
+      </article>
+    </template>
+
+    <script src="/public/app.js" defer></script>
+  </body>
+</html>
